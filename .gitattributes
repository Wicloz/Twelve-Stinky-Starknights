# Normalize EOL for all files that Git considers text files.
* text=auto eol=lf

# Track all binary assets using Git LFS.
assets/**/*.png   filter=lfs diff=lfs merge=lfs -text
assets/**/*.webp  filter=lfs diff=lfs merge=lfs -text
assets/**/*.svg   filter=lfs diff=lfs merge=lfs -text
assets/**/*.ogg   filter=lfs diff=lfs merge=lfs -text
assets/**/*.ogv   filter=lfs diff=lfs merge=lfs -text
assets/**/*.jpeg  filter=lfs diff=lfs merge=lfs -text
assets/**/*.jpg   filter=lfs diff=lfs merge=lfs -text
assets/**/*.wav   filter=lfs diff=lfs merge=lfs -text
assets/**/*.pdn   filter=lfs diff=lfs merge=lfs -text
